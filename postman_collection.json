            ],
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": ["{{baseUrl}}"],
              "path": ["cart"]
            },
            "description": "Use either `token` for logged-in users or `x-guest-id` for guests."
          },
          "response": []
        },
        {
          "name": "Add To Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const guestIdHeader = pm.response.headers.get('x-guest-id');",
                  "if (guestIdHeader) pm.environment.set('guestId', guestIdHeader);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "token", "value": "{{token}}", "disabled": true },
              { "key": "x-guest-id", "value": "{{guestId}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": ["{{baseUrl}}"],
              "path": ["cart"]
            },
            "description": "For guest carts, if `x-guest-id` is empty the API may return a generated one in response headers."
          },
          "response": []
        },
