{
	"info": {
		"name": "E-Commerce API",
		"description": "API collection: Authentication (Email Confirmation), Profile, Wishlist & Reviews",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Register Customer",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"age\": 25,\n  \"role\": \"customer\"\n}"
						},
						"url": {"raw": "http://localhost:3000/register", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["register"]}
					}
				},
				{
					"name": "Register with Phone",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Jane Smith\",\n  \"phone\": \"1234567890\",\n  \"password\": \"password123\",\n  \"role\": \"customer\"\n}"
						},
						"url": {"raw": "http://localhost:3000/register", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["register"]}
					}
				},
				{
					"name": "Register Admin",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\",\n  \"role\": \"admin\"\n}"
						},
						"url": {"raw": "http://localhost:3000/register", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["register"]}
					}
				},
				{
					"name": "Confirm Email",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:3000/confirm-email/:token", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["confirm-email", ":token"], "variable": [{"key": "token", "value": "paste_token_from_email"}]}
					}
				},
				{
					"name": "Login with Email",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {"raw": "http://localhost:3000/login", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["login"]}
					}
				},
				{
					"name": "Login with Phone",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"1234567890\",\n  \"password\": \"password123\"\n}"
						},
						"url": {"raw": "http://localhost:3000/login", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["login"]}
					}
				},
				{
					"name": "Get All Users (Admin)",
					"request": {
						"method": "GET",
						"header": [{"key": "token", "value": "{{admin_token}}"}],
						"url": {"raw": "http://localhost:3000/users", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users"]}
					}
				},
				{
					"name": "Get User by ID",
					"request": {
						"method": "GET",
						"header": [{"key": "token", "value": "{{user_token}}"}],
						"url": {"raw": "http://localhost:3000/users/:id", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users", ":id"], "variable": [{"key": "id", "value": "user_id_here"}]}
					}
				},
				{
					"name": "Update User",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "token", "value": "{{user_token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Updated\",\n  \"age\": 26\n}"
						},
						"url": {"raw": "http://localhost:3000/users/:id", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users", ":id"], "variable": [{"key": "id", "value": "user_id_here"}]}
					}
				},
				{
					"name": "Delete User",
					"request": {
						"method": "DELETE",
						"header": [{"key": "token", "value": "{{user_token}}"}],
						"url": {"raw": "http://localhost:3000/users/:id", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["users", ":id"], "variable": [{"key": "id", "value": "user_id_here"}]}
					}
				}
			]
		},
		{
			"name": "2. Profile Management",
			"item": [
				{
					"name": "Create Profile",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "token", "value": "{{user_token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"address\": \"123 Main Street\",\n  \"city\": \"New York\",\n  \"state\": \"NY\",\n  \"zipCode\": \"10001\",\n  \"country\": \"USA\",\n  \"phone\": \"1234567890\"\n}"
						},
						"url": {"raw": "http://localhost:3000/profile", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["profile"]}
					}
				},
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"header": [{"key": "token", "value": "{{user_token}}"}],
						"url": {"raw": "http://localhost:3000/profile", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["profile"]}
					}
				},
				{
					"name": "Update Profile",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "token", "value": "{{user_token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"address\": \"456 Oak Avenue\",\n  \"city\": \"Los Angeles\",\n  \"state\": \"CA\",\n  \"zipCode\": \"90001\",\n  \"country\": \"USA\"\n}"
						},
						"url": {"raw": "http://localhost:3000/profile", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["profile"]}
					}
				},
				{
					"name": "Add Payment Method (Credit Card)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "token", "value": "{{user_token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"type\": \"credit_card\",\n  \"cardNumber\": \"1234567890123456\",\n  \"cardHolderName\": \"John Doe\",\n  \"expiryDate\": \"12/25\",\n  \"cvv\": \"123\"\n}"
						},
						"url": {"raw": "http://localhost:3000/profile/payment", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["profile", "payment"]}
					}
				},
				{
					"name": "Add Payment Method (PayPal)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "token", "value": "{{user_token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"type\": \"paypal\",\n  \"email\": \"john@paypal.com\"\n}"
						},
						"url": {"raw": "http://localhost:3000/profile/payment", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["profile", "payment"]}
					}
				},
				{
					"name": "Remove Payment Method",
					"request": {
						"method": "DELETE",
						"header": [{"key": "token", "value": "{{user_token}}"}],
						"url": {"raw": "http://localhost:3000/profile/payment/:paymentId", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["profile", "payment", ":paymentId"], "variable": [{"key": "paymentId", "value": "payment_id_here"}]}
					}
				}
			]
		},
		{
			"name": "3. Wishlist",
			"item": [
				{
					"name": "Get Wishlist",
					"request": {
						"method": "GET",
						"header": [{"key": "token", "value": "{{user_token}}"}],
						"url": {"raw": "http://localhost:3000/wishlist", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["wishlist"]}
					}
				},
				{
					"name": "Add to Wishlist",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "token", "value": "{{user_token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": \"product_id_here\"\n}"
						},
						"url": {"raw": "http://localhost:3000/wishlist", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["wishlist"]}
					}
				},
				{
					"name": "Remove from Wishlist",
					"request": {
						"method": "DELETE",
						"header": [{"key": "token", "value": "{{user_token}}"}],
						"url": {"raw": "http://localhost:3000/wishlist/:productId", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["wishlist", ":productId"], "variable": [{"key": "productId", "value": "product_id_here"}]}
					}
				},
				{
					"name": "Check if in Wishlist",
					"request": {
						"method": "GET",
						"header": [{"key": "token", "value": "{{user_token}}"}],
						"url": {"raw": "http://localhost:3000/wishlist/check/:productId", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["wishlist", "check", ":productId"], "variable": [{"key": "productId", "value": "product_id_here"}]}
					}
				}
			]
		},
		{
			"name": "4. Reviews & Ratings",
			"item": [
				{
					"name": "Get Product Reviews",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:3000/products/:productId/reviews", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["products", ":productId", "reviews"], "variable": [{"key": "productId", "value": "product_id_here"}]}
					}
				},
				{
					"name": "Get Product Rating",
					"request": {
						"method": "GET",
						"url": {"raw": "http://localhost:3000/products/:productId/rating", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["products", ":productId", "rating"], "variable": [{"key": "productId", "value": "product_id_here"}]}
					}
				},
				{
					"name": "Get My Reviews",
					"request": {
						"method": "GET",
						"header": [{"key": "token", "value": "{{user_token}}"}],
						"url": {"raw": "http://localhost:3000/reviews", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["reviews"]}
					}
				},
				{
					"name": "Add Review",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "token", "value": "{{user_token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": \"product_id_here\",\n  \"rating\": 5,\n  \"comment\": \"Excellent product! Highly recommended.\"\n}"
						},
						"url": {"raw": "http://localhost:3000/reviews", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["reviews"]}
					}
				},
				{
					"name": "Update Review",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "token", "value": "{{user_token}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"rating\": 4,\n  \"comment\": \"Good product, but could be better.\"\n}"
						},
						"url": {"raw": "http://localhost:3000/reviews/:id", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["reviews", ":id"], "variable": [{"key": "id", "value": "review_id_here"}]}
					}
				},
				{
					"name": "Delete Review",
					"request": {
						"method": "DELETE",
						"header": [{"key": "token", "value": "{{user_token}}"}],
						"url": {"raw": "http://localhost:3000/reviews/:id", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["reviews", ":id"], "variable": [{"key": "id", "value": "review_id_here"}]}
					}
				}
			]
		}
	],
	"variable": [
		{"key": "base_url", "value": "http://localhost:3000"},
		{"key": "user_token", "value": "paste_your_user_token_here"},
		{"key": "admin_token", "value": "paste_your_admin_token_here"}
	]
}
