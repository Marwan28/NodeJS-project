{
	"info": {
		"name": "💳 Simple Payment API",
		"description": "One endpoint to create payment and get PayPal link (Authenticated users only)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "🎯 Create Payment (Get PayPal Link)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    const response = pm.response.json();",
							"    console.log('✅ Payment URL:', response.paymentUrl);",
							"    console.log('💰 Amount:', response.amount);",
							"    console.log('📝 Order ID:', response.orderId);",
							"    console.log('');",
							"    console.log('👉 Open this URL in browser to pay:');",
							"    console.log(response.paymentUrl);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "token",
						"value": "{{user_token}}",
						"description": "Required: User JWT token"
					}
				],
				"body": {
					"mode": "raw",
					"raw": ""
				},
				"url": {
					"raw": "{{base_url}}/payment/create",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"payment",
						"create"
					]
				},
				"description": "Creates PayPal payment and returns payment URL.\n\n**Requirements:**\n- User must be logged in (token required)\n- Cart must have items\n\n**How it works:**\n1. Backend gets user's cart from database\n2. Calculates total amount\n3. Verifies stock availability\n4. Creates PayPal order\n5. Returns payment URL\n\n**What to do:**\n1. Login first to get token\n2. Add items to cart\n3. Send this request with token\n4. Copy the `paymentUrl` from response\n5. Open it in browser\n6. Pay with PayPal Sandbox account\n7. Done! ✅"
			},
			"response": [
				{
					"name": "Success Response",
					"originalRequest": {
						"method": "POST",
						"header": [
							{
								"key": "token",
								"value": "{{user_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/payment/create",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"payment",
								"create"
							]
						}
					},
					"status": "OK",
					"code": 200,
					"_postman_previewlanguage": "json",
					"header": [],
					"cookie": [],
					"body": "{\n    \"success\": true,\n    \"paymentUrl\": \"https://www.sandbox.paypal.com/checkoutnow?token=7XY12345ABC\",\n    \"amount\": 150.50,\n    \"orderId\": \"7XY12345ABC\"\n}"
				},
				{
					"name": "Error: Not Logged In",
					"originalRequest": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/payment/create",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"payment",
								"create"
							]
						}
					},
					"status": "Unauthorized",
					"code": 401,
					"_postman_previewlanguage": "json",
					"header": [],
					"cookie": [],
					"body": "{\n    \"message\": \"Please login to checkout\"\n}"
				},
				{
					"name": "Error: Empty Cart",
					"originalRequest": {
						"method": "POST",
						"header": [
							{
								"key": "token",
								"value": "{{user_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/payment/create",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"payment",
								"create"
							]
						}
					},
					"status": "Bad Request",
					"code": 400,
					"_postman_previewlanguage": "json",
					"header": [],
					"cookie": [],
					"body": "{\n    \"message\": \"Your cart is empty\"\n}"
				}
			]
		},
		{
			"name": "📦 Step 1: Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 200) {",
							"    const response = pm.response.json();",
							"    pm.environment.set('user_token', response.token);",
							"    console.log('✅ Logged in successfully');",
							"    console.log('Token saved to environment');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"123456\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/login",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"login"
					]
				},
				"description": "Login to get JWT token"
			},
			"response": []
		},
		{
			"name": "📦 Step 2: Add to Cart",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "token",
						"value": "{{user_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"productId\": \"{{product_id}}\",\n    \"quantity\": 2\n}"
				},
				"url": {
					"raw": "{{base_url}}/cart",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"cart"
					]
				},
				"description": "Add items to cart before creating payment"
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000"
		},
		{
			"key": "user_token",
			"value": ""
		},
		{
			"key": "product_id",
			"value": ""
		}
	]
}
